<Window x:Class="LPTUnoApp.WifiSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar WiFi (Arduino UNO R4)" Height="200" Width="350" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="10">
        <TextBlock Text="SSID (Nome da Rede):" Margin="0,0,0,5"/>
        <TextBox Name="TxtSsid" Margin="0,0,0,10"/>
        
        <TextBlock Text="Password (Senha):" Margin="0,0,0,5"/>
        <PasswordBox Name="TxtPass" Margin="0,0,0,15"/>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="BtnCancel" Content="Cancelar" Width="80" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Name="BtnSave" Content="Salvar no Arduino" Width="120" Click="BtnSave_Click"/>
        </StackPanel>
    </StackPanel>
</Window>